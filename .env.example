# Lumina Study Platform - Environment Variables Template
# Copy this file to .env and fill in the actual secret values.
# IMPORTANT: Never commit your actual .env file or real API keys to a public GitHub repository!

# Google Gemini API Key (Required for automated lesson processing and Q&A chat)
# Get your free key on Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Cookie signing secret used by the Express API and the optional Django API.
# Use a long random value in production.
SESSION_SECRET=change_me_to_a_long_random_secret

# PostgreSQL connection string (Recommended for production persistence such as Supabase)
# Example format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=

# The URL where this application is hosted
APP_URL=http://localhost:3000

# Optional Django admin/API configuration.
DJANGO_SECRET_KEY=change_me_for_django_admin
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Credentials (if using Supabase authentication or direct client integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
